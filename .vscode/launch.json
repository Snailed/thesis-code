{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [
                "${command:pickArgs}"
            ]
        },
        {
            "name": "Small measurement",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
            "cwd": "${cwd}/prep-project",
            "args": [
                "--dataset=SineRegression",
                "--experiment=HMC",
                "--num_samples=50",
                "--num_warmup=150",
                "--num_chains=8",
                "--show=False",
                "--seed=100",
                "--init_strategy=init_to_sample",
                "--model",
                "Exp2Reg_3_deep_20_wide",
                "Exp2Circ_3_deep_20_wide"
            ]
        },
        {
            "name": "Experiment 1",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
            "cwd": "${cwd}/prep-project",
            "args": [
                "--dataset=SineRegression",
                "--experiment=HMC",
                "--num_samples=50",
                "--num_warmup=200",
                "--num_chains=8",
                "--seed=165",
                "--init_strategy=init_to_sample",
                "--model",
                "Exp1Reg_1_deep",
                "Exp1Reg_2_deep",
                "Exp1Reg_3_deep",
                "Exp1Reg_4_deep",
                "Exp1Circ_1_deep",
                "Exp1Circ_2_deep",
                "Exp1Circ_3_deep",
                "Exp1Circ_4_deep",
            ]
        },
        {
            "name": "Dry run",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
            "cwd": "${cwd}/prep-project",
            "args": [
                "--dry_run=True",
                "--dataset=SineRegression",
                "--experiment=HMC",
                "--init_strategy=init_to_sample",
                "--num_chains=2",
                "--seed=50",
                "--model",
                "SimpleCirc_2_deep_4_wide",
                "SimpleReg_2_deep_4_wide",
                "SimpleReg_3_deep_4_wide",
            ]
        }
    ]
}